# Python build / cache artifacts. The plugin tree itself is declarative
# config + rendered skills, but the dev/test harness (uv + pytest +
# editable guide-cli) emits these.
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.venv/

# Reserved for forward-compat. Today no operator state lives under the
# plugin tree (unlike the Hermes plugin's `.local/`), but if a future
# release adds per-project state, this is where it goes.
.local/
